{
  "name": "toolcase-self-improve",
  "version": "5.0.1",
  "author": "SmokerGreenOG",
  "description": "ToolCase v3.0 — 35 tools, self-improvement loop, 10 safety rules, EN/NL/DE i18n",
  "hermes": {
    "skill_type": "workflow",
    "tags": [
      "toolcase",
      "self-improvement",
      "code-quality",
      "automation",
      "safety-first"
    ],
    "trigger_conditions": [
      "User asks to check/improve code quality",
      "User mentions ToolCase, improve.py, or self-improve",
      "User wants an automated code audit",
      "User wants a security scan of their project",
      "User asks for a full project health check"
    ],
    "entry_points": {
      "self_improve_loop": {
        "script": "self_improve_loop.py",
        "command": "python self_improve_loop.py [--cycles N] [--target PATH] [--dry-run] [--json]",
        "description": "Full 13-step self-improvement loop"
      },
      "improve": {
        "script": "improve.py",
        "command": "python improve.py <file> [--list-tools] [--lang en|nl|de]",
        "description": "Main orchestrator — all 35 tools"
      }
    },
    "safety_rules": [
      "Never modify files without backup",
      "Never read or print .env, API keys or secrets",
      "Never run destructive commands",
      "Never write outside workspace",
      "Never delete files without explicit approval",
      "Never modify config files without file_guard.py",
      "Never run terminal commands without command_guard.py",
      "Never apply a patch without patch_preview.py",
      "Never continue if tests/build get worse",
      "If an improvement fails: rollback immediately"
    ]
  },
  "tools": [
    {
      "id": 1,
      "name": "improve",
      "script": "improve.py",
      "type": "Scan",
      "risk": "Low",
      "desc": "Python syntax + lint (lange regels, trailing whitespace, TODO/FIXME)"
    },
    {
      "id": 2,
      "name": "multiscan",
      "script": "multiscan.py",
      "type": "Scan",
      "risk": "Low",
      "desc": "Multi-language scan (.py/.ts/.tsx/.rs)"
    },
    {
      "id": 3,
      "name": "complexity",
      "script": "complexity.py",
      "type": "Analyze",
      "risk": "Low",
      "desc": "Cyclomatic complexity & cognitive load"
    },
    {
      "id": 4,
      "name": "depgraph",
      "script": "depgraph.py",
      "type": "Analyze",
      "risk": "Low",
      "desc": "Import/export dependency graph + circular deps"
    },
    {
      "id": 5,
      "name": "patch_preview",
      "script": "patch_preview.py",
      "type": "Patch",
      "risk": "Low",
      "desc": "Diff preview before applying patches"
    },
    {
      "id": 6,
      "name": "dead_code",
      "script": "dead_code_finder.py",
      "type": "Analyze",
      "risk": "Low",
      "desc": "Unused imports, dead functions, commented-out code"
    },
    {
      "id": 7,
      "name": "security_scan",
      "script": "security_scan.py",
      "type": "Scan",
      "risk": "Low",
      "desc": "Hardcoded secrets, API keys, eval/exec, SQL injection"
    },
    {
      "id": 8,
      "name": "env_check",
      "script": "env_check.py",
      "type": "Scan",
      "risk": "Low",
      "desc": ".env check, missing variables, .env.example"
    },
    {
      "id": 9,
      "name": "dependency_audit",
      "script": "dependency_audit.py",
      "type": "Analyze",
      "risk": "Low",
      "desc": "Python/Node/Rust dependency audit"
    },
    {
      "id": 10,
      "name": "project_doctor",
      "script": "project_doctor.py",
      "type": "Analyze",
      "risk": "Low",
      "desc": "Project structure, init.py, git, naming conventions"
    },
    {
      "id": 11,
      "name": "workspace_index",
